{
  "name": "papertrail-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Evaluation harness for PaperTrail-Bench: corpus loader, deterministic scorers, adapter protocol, oracle self-test.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "papertrail-eval": "node dist/cli.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "better-sqlite3": "^12.11.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
